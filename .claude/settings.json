{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | grep '\\.rb$' | xargs bundle exec rubocop --autocorrect",
            "timeout": 60,
            "statusMessage": "Running RuboCop..."
          }
        ]
      }
    ]
  }
}
